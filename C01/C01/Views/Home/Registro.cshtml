@model ReservaModel
@{
    Layout = "_LayoutExterno";
}

<div class="row justify-content-center">
    <div class="page-header">
        <a asp-action="Index" asp-controller="Home"
           class="btn btn-gradient-danger btn-rounded btn-fw">
            <i class="mdi mdi-arrow-left"></i>
            Ir al Inicio
        </a>
    </div>

    <div class="col-md-6 grid-margin stretch-card">
        <div class="card bg-gradient-info card-img-holder text-white">
            <div class="card-body">

                <img src="~/image/circle.svg" class="card-img-absolute" alt="circle-image" />

                <h4 class="card-title text-center text-white">Registro de Reserva</h4>

                @if (TempData["Mensaje"] != null)
                {
                    <div class="alert alert-@TempData["TipoMensaje"] text-center" role="alert">
                        @TempData["Mensaje"]
                    </div>
                }

                <form id="Registro" asp-action="Registro" asp-controller="Home" method="post">

                    <div class="form-group">
                        <label>Número de habitación</label>
                        <input asp-for="NumeroHabitacion"
                               type="text"
                               class="form-control form-control-xl" />

                        <span asp-validation-for="NumeroHabitacion" class="text-warning"></span>
                    </div>

                    <div class="form-group">
                        <label>Monto total</label>
                        <input asp-for="MontoTotal"
                               type="number"
                               step="0.01"
                               min="0.01"
                               class="form-control form-control-xl" />

                        <span asp-validation-for="MontoTotal" class="text-warning"></span>
                    </div>

                    <div class="form-group">
                        <label>Tipo de habitación</label>

                        <select asp-for="TipoHabitacion"
                                asp-items="Model.TiposHabitaciones"
                                class="form-select cliente-select">
                            <option value="">Seleccione un tipo de habitación</option>
                        </select>

                        <span asp-validation-for="TipoHabitacion" class="text-warning"></span>
                    </div>

                    <button type="submit" class="btn btn-gradient-danger btn-rounded btn-fw me-2">
                        Procesar
                    </button>
                </form>

            </div>
        </div>
    </div>
</div>

<script src="~/js/registrarH.js"></script>