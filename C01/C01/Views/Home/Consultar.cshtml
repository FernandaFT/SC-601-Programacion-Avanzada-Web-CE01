@model List<C01.Models.ConsultaReservaModel>

@{
    Layout = "_LayoutExterno";
}

<div class="main-panel">
    <div class="content-wrapper">
        <div class="page-header">
            <a asp-action="Index" asp-controller="Home"
               class="btn btn-gradient-danger btn-rounded btn-fw">
                <i class="mdi mdi-arrow-left"></i>
                Ir al Inicio
            </a>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-12 grid-margin stretch-card">
                <div class="card bg-gradient-success card-img-holder">
                    <div class="card-body">
                        <img src="~/image/circle.svg" class="card-img-absolute" alt="circle-image" />

                        <h4 class="card-title text-center">
                            Consulta de Reservas
                        </h4>

                        <table class="table text-center">
                            <thead>
                                <tr>
                                    <th>Fecha de reserva</th>
                                    <th>Monto total</th>
                                    <th>Tipo de habitación</th>
                                    <th>Número de habitación</th>
                                </tr>
                            </thead>

                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@item.FechaReserva.ToString("dd/MM/yyyy")</td>
                                            <td>₡@item.MontoTotal.ToString("N2")</td>
                                            <td>@item.DescripcionTipo</td>
                                            <td>@item.NumeroHabitacion</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4">No hay reservas registradas</td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>