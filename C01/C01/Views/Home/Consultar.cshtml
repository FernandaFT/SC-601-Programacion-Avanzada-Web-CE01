@* @model List<C01.Models.ConsultaModel>
 *@
@{
    Layout = "_LayoutExterno";
}

<div class="main-panel">
    <div class="content-wrapper">
        <div class="page-header">
            <a asp-action="Index" asp-controller="Home"
               class="btn btn-gradient-danger btn-rounded btn-fw">
                <i class="mdi mdi-arrow-left"></i>
                Ir al Inicio
            </a>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-12 grid-margin stretch-card">
                <div class="card bg-gradient-success card-img-holder">
                    <div class="card-body">
                        <img src="~/image/circle.svg" class="card-img-absolute" alt="circle-image" />

                        <h4 class="card-title text-center">
                            Consulta
                        </h4>

                        <table class="table text-center">
                            <thead>
                                <tr>
                                    <th>Cédula del cliente</th>
                                    <th>Nombre del cliente</th>
                                    <th>Nombre de la mascota</th>
                                    <th>Especie</th>
                                    <th>Peso</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@item.CedulaCliente</td>
                                            <td>@item.NombreCliente</td>
                                            <td>@item.NombreMascota</td>
                                            <td>@item.Especie</td>
                                            <td>@item.Peso.ToString("N2")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5">No hay datos para mostrar</td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
